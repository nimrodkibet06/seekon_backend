# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Connection (MongoDB)
# You can set MONGO_URI or DATABASE_URL
MONGO_URI=mongodb://localhost:27017/seekon-apparel
DATABASE_URL=mongodb://localhost:27017/seekon-apparel

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Cloudinary Configuration
# You can configure individual keys OR use CLOUDINARY_URL (e.g., cloudinary://key:secret@cloud_name)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Background Removal Tool API
# Get your API key from https://www.remove.bg/
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# Payment Integration: Paystack (Required for checkouts)
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# Payment Integration: M-Pesa (Daraja)
CONSUMER_KEY=your_consumer_key
CONSUMER_SECRET=your_consumer_secret
SHORTCODE=your_business_shortcode
PASSKEY=your_passkey
CALLBACK_URL=http://4.224.81.245:5000/api/payment/mpesa-callback

# Payment Integration: Flutterwave
FLW_SECRET_KEY=your_flutterwave_secret_key
FLW_PUBLIC_KEY=your_flutterwave_public_key

# Email Sending: Resend API (Recommended)
RESEND_API_KEY=re_your_resend_api_key

# Email Sending: SMTP/Nodemailer Fallback
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Seekon AI Shopping Assistant (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Email Validation: Abstract API
ABSTRACT_EMAIL_API_KEY=your_abstract_api_key

# Google Drive Automatic Database Backups
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
BACKUP_RETENTION_DAYS=30
